# SoulFlame AI Echo / AI Twin
# Copy needed values to .env locally or Vercel Environment Variables.

# Required for GPT API:
OPENAI_API_KEY=sk-your-key-here

# Default model used by /api/chat.js when frontend does not send a model:
AI_TWIN_MODEL=gpt-4o-mini

# Optional Supabase vars if your backend already uses them:
DATA_MODE=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
